{
  "name": "caddisfly",
  "version": "1.0.0",
  "description": "Caddisfly - Modern Website Refactoring Service",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:prod": "wrangler deploy --env production",
    "db:create": "wrangler d1 create caddisfly-db",
    "db:migrate:local": "wrangler d1 execute caddisfly-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute caddisfly-db --remote --file=./schema.sql",
    "db:query:local": "wrangler d1 execute caddisfly-db --local --command",
    "db:query:remote": "wrangler d1 execute caddisfly-db --remote --command",
    "r2:create": "wrangler r2 bucket create caddisfly-storage",
    "r2:list": "wrangler r2 bucket list",
    "secret:preview:google-client-id": "wrangler secret put GOOGLE_CLIENT_ID --env preview",
    "secret:preview:google-client-secret": "wrangler secret put GOOGLE_CLIENT_SECRET --env preview",
    "secret:prod:google-client-id": "wrangler secret put GOOGLE_CLIENT_ID --env production",
    "secret:prod:google-client-secret": "wrangler secret put GOOGLE_CLIENT_SECRET --env production"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "website",
    "refactoring",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  }
}
